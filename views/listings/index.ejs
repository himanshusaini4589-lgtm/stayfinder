<%layout("/layouts/boilerplate")%>
<body>
    <h3>All Listings</h3>
    <form method = "GET" action = "/listings/new" >
        <button>Create New List</button>
    </form>
    <% for(listing of allListings){ %>
        <ul>
            <li><a href = "/listings/<%=listing._id%>"><%=listing.title%></a></li>
        </ul>
    <% } %>
</body>
